#!/usr/bin/env bash
# Pre-commit hook: auto-format staged files, then run Go tests with coverage check
# Excludes infrastructure packages (cli, config, database, cmd, testutil)
# that require full application context and are not unit-testable.

set -e

# --- Auto-format staged files ---

# Format staged Go files with gofmt
STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.go')
if [ -n "$STAGED_GO_FILES" ]; then
    echo "Formatting Go files..."
    echo "$STAGED_GO_FILES" | xargs gofmt -w
    echo "$STAGED_GO_FILES" | xargs git add
fi

# Format staged frontend files with prettier
STAGED_FRONTEND_FILES=$(git diff --cached --name-only --diff-filter=ACM -- 'frontend/src/*.svelte' 'frontend/src/*.ts' 'frontend/src/*.js')
if [ -n "$STAGED_FRONTEND_FILES" ]; then
    echo "Formatting frontend files..."
    cd frontend
    echo "$STAGED_FRONTEND_FILES" | sed 's|^frontend/||' | xargs npx prettier --write
    cd ..
    echo "$STAGED_FRONTEND_FILES" | xargs git add
fi

# --- Tests ---

MIN_COVERAGE=80

echo "Running Go tests with coverage check..."

# Run tests and capture coverage
COVER_OUT=$(mktemp)
trap 'rm -f "$COVER_OUT"' EXIT

if ! CGO_ENABLED=0 go test -tags server ./... -coverprofile="$COVER_OUT" -count=1 > /dev/null 2>&1; then
    echo "FAIL: Go tests failed"
    CGO_ENABLED=0 go test -tags server ./... -count=1
    exit 1
fi

# Calculate coverage excluding non-testable packages
EXCLUDED="cmd/|frontend/|internal/cli/|internal/config/|internal/database/|internal/app/|internal/server/|internal/testutil/"
TOTAL=$(go tool cover -func="$COVER_OUT" \
    | grep -v "total:" \
    | grep -vE "$EXCLUDED" \
    | awk '{pct=$NF+0; if($NF ~ /%/) {hit+=pct; cnt++}} END {if(cnt>0) printf "%.1f", hit/cnt; else print "0"}')
TOTAL_INT=${TOTAL%.*}

if [ "$TOTAL_INT" -lt "$MIN_COVERAGE" ]; then
    echo "FAIL: Go test coverage ${TOTAL}% is below minimum ${MIN_COVERAGE}% (testable packages)"
    echo "Run 'make coverage-go' for details."
    exit 1
fi

echo "OK: Go test coverage ${TOTAL}% (minimum ${MIN_COVERAGE}%, testable packages)"
